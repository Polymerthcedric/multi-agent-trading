// Multi-Agent Trading Bot - TradingView Indicator
// Displays bot signals, support/resistance, and agent analysis overlay
// Works with: GOLD/USD, Silver, Forex, Stocks, ETFs

//@version=6
indicator("Multi-Agent Trading Bot", overlay=true, max_labels_count=500, max_lines_count=100)

// === INPUTS ===
showSignals = input.bool(true, "Show Bot Signals")
showSR = input.bool(true, "Show Support/Resistance")
showAgentOverlay = input.bool(true, "Show Agent Analysis")
showDashboard = input.bool(true, "Show Dashboard")
lookbackLen = input.int(20, "Lookback Length", minval=5, maxval=100)

// === RSI ===
rsiLen = input.int(14, "RSI Length")
rsiVal = ta.rsi(close, rsiLen)

// === SMA / EMA ===
sma20 = ta.sma(close, 20)
ema20 = ta.ema(close, 20)
sma50 = ta.sma(close, 50)

// === MACD ===
[macdLine, signalLine, histLine] = ta.macd(close, 12, 26, 9)

// === ADX ===
adxLen = input.int(14, "ADX Length")
adxVal = ta.rma(math.abs(ta.change(close)), adxLen)
adxPlus = ta.rma(math.max(ta.change(close), 0), adxLen)
adxMinus = ta.rma(math.max(-ta.change(close), 0), adxLen)
diPlus = adxPlus / adxVal * 100
diMinus = adxMinus / adxVal * 100
adx = math.abs(diPlus - diMinus) / (diPlus + diMinus) * 100

// === Bollinger Bands ===
bbBasis = ta.sma(close, 20)
bbDev = ta.stdev(close, 20) * 2.0
bbUpper = bbBasis + bbDev
bbLower = bbBasis - bbDev

// === ATR ===
atrVal = ta.atr(14)

// === AGENT SIGNALS ===
// Predictive Agent: RSI + MACD + EMA crossover
predBullish = rsiVal < 40 and macdLine > signalLine and ema20 > sma20
predBearish = rsiVal > 60 and macdLine < signalLine and ema20 < sma20

// Context Agent: Regime detection
ctxBullish = close > sma20 and close > sma50 and adx > 25
ctxBearish = close < sma20 and close < sma50 and adx > 25

// Volatility Agent: BB position + ATR
volLow = close < bbLower
volHigh = close > bbUpper

// Risk Manager: Consensus
buySignal = predBullish and ctxBullish
sellSignal = predBearish and ctxBearish

// === MARKER COLORS ===
buyColor = color.new(#22c55e, 0)
sellColor = color.new(#ef4444, 0)
neutralColor = color.new(#6b7280, 0)

// === SIGNAL MARKERS ===
plotshape(showSignals and buySignal, title="BUY", style=shape.triangleup, location=location.belowbar, color=buyColor, size=size.normal, text="BUY")
plotshape(showSignals and sellSignal, title="SELL", style=shape.triangledown, location=location.abovebar, color=sellColor, size=size.normal, text="SELL")

// === SUPPORT / RESISTANCE ===
support = ta.lowest(low, lookbackLen)
resistance = ta.highest(high, lookbackLen)

plot(showSR ? support : na, title="Support", color=color.new(#22c55e, 60), style=plot.style_linebr, linewidth=2)
plot(showSR ? resistance : na, title="Resistance", color=color.new(#ef4444, 60), style=plot.style_linebr, linewidth=2)

// === EMA / SMA LINES ===
plot(ema20, title="EMA20", color=color.new(#06b6d4, 30), linewidth=1)
plot(sma20, title="SMA20", color=color.new(#f59e0b, 30), linewidth=1)
plot(sma50, title="SMA50", color=color.new(#8b5cf6, 50), linewidth=1)

// === FILL BETWEEN BB ===
p1 = plot(bbUpper, title="BB Upper", color=color.new(#ef4444, 80))
p2 = plot(bbLower, title="BB Lower", color=color.new(#22c55e, 80))
fill(p1, p2, color=color.new(#3b82f6, 90), title="BB Fill")

// === ALERTS ===
alertcondition(buySignal, title="Bot BUY Signal", message="Multi-Agent Bot: BUY {{ticker}} @ {{close}}")
alertcondition(sellSignal, title="Bot SELL Signal", message="Multi-Agent Bot: SELL {{ticker}} @ {{close}}")

// === DASHBOARD TABLE ===
if showDashboard and barstate.islast
    var table dash = table.new(position.top_right, 4, 8, bgcolor=color.new(#1e293b, 10), border_color=color.new(#334155, 0), border_width=1)

    table.cell(dash, 0, 0, "Agent", text_color=color.new(#94a3b8, 0), text_size=size.small)
    table.cell(dash, 1, 0, "Signal", text_color=color.new(#94a3b8, 0), text_size=size.small)
    table.cell(dash, 2, 0, "Value", text_color=color.new(#94a3b8, 0), text_size=size.small)
    table.cell(dash, 3, 0, "Status", text_color=color.new(#94a3b8, 0), text_size=size.small)

    predStatus = predBullish ? "BULL" : predBearish ? "BEAR" : "NEUTRAL"
    predColor = predBullish ? buyColor : predBearish ? sellColor : neutralColor
    table.cell(dash, 0, 1, "Predictive", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 1, predStatus, text_color=predColor, text_size=size.small)
    table.cell(dash, 2, 1, "RSI:" + str.tostring(rsiVal, "#.0"), text_color=color.white, text_size=size.small)
    table.cell(dash, 3, 1, macdLine > signalLine ? "MACD+" : "MACD-", text_color=color.white, text_size=size.small)

    ctxStatus = ctxBullish ? "BULL" : ctxBearish ? "BEAR" : "NEUTRAL"
    ctxColor = ctxBullish ? buyColor : ctxBearish ? sellColor : neutralColor
    table.cell(dash, 0, 2, "Context", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 2, ctxStatus, text_color=ctxColor, text_size=size.small)
    table.cell(dash, 2, 2, "ADX:" + str.tostring(adx, "#.0"), text_color=color.white, text_size=size.small)
    table.cell(dash, 3, 2, close > sma20 ? "Above SMA" : "Below SMA", text_color=color.white, text_size=size.small)

    volStatus = volLow ? "OVERSOLD" : volHigh ? "OVERBOUGHT" : "NORMAL"
    volColor = volLow ? buyColor : volHigh ? sellColor : neutralColor
    table.cell(dash, 0, 3, "Volatility", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 3, volStatus, text_color=volColor, text_size=size.small)
    table.cell(dash, 2, 3, "ATR:" + str.tostring(atrVal, "#.####"), text_color=color.white, text_size=size.small)
    table.cell(dash, 3, 3, "BB:" + str.tostring((close - bbLower) / (bbUpper - bbLower) * 100, "#.0") + "%", text_color=color.white, text_size=size.small)

    riskStatus = buySignal ? "BUY" : sellSignal ? "SELL" : "HOLD"
    riskColor = buySignal ? buyColor : sellSignal ? sellColor : neutralColor
    table.cell(dash, 0, 4, "Risk", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 4, riskStatus, text_color=riskColor, text_size=size.small)
    table.cell(dash, 2, 4, "SL:" + str.tostring(close * 0.98, "#.##"), text_color=color.white, text_size=size.small)
    table.cell(dash, 3, 4, "TP:" + str.tostring(close * 1.03, "#.##"), text_color=color.white, text_size=size.small)

    table.cell(dash, 0, 5, "Price", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 5, str.tostring(close, "#.#####"), text_color=color.white, text_size=size.small)
    table.cell(dash, 2, 5, "S/R", text_color=color.white, text_size=size.small)
    table.cell(dash, 3, 5, str.tostring(support, "#.#####") + " / " + str.tostring(resistance, "#.#####"), text_color=color.white, text_size=size.small)
